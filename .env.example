# Copy this file to .env and fill runtime secrets locally.
# .env is ignored by git.

# LLM provider: gemini or nvidia.
LLM_PROVIDER=gemini

# Google Gemini API key from Google AI Studio.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# NVIDIA NIM API key from NVIDIA Build.
# To use it, set LLM_PROVIDER=nvidia and fill NVIDIA_API_KEY.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1

# Optional override for whichever provider is selected.
# ANSWER_MODEL=
# EVAL_MODELS=

# Ask the provider for strict JSON output via response_format. Default on;
# answer.py falls back to prompt-only JSON if a provider/model rejects it.
# LLM_JSON_MODE=true

# LLM request timeout in seconds. Kept below the bot's 45s answer wait so a
# stalled provider fails closed instead of hanging the call.
# LLM_TIMEOUT=30

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Retrieval settings.
TOP_K=4
RETRIEVAL_MAX_DISTANCE=1.2

# Semantic router thresholds (see rag_bot/router.py; calibrated against
# eval/routing_set.yaml).
# Minimum cosine similarity to a domain anchor for FACTUAL_IN_DOMAIN routing.
# ROUTER_IN_DOMAIN_MIN=0.42
# Minimum lead an in-domain score needs over the best out-of-domain score.
# ROUTER_MARGIN=0.05
# Minimum cosine similarity to a smalltalk anchor for SMALLTALK routing.
# ROUTER_SMALLTALK_MIN=0.50
