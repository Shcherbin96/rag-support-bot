# Copy this file to .env and fill runtime secrets locally.
# .env is ignored by git.

# LLM provider: gemini or nvidia.
LLM_PROVIDER=gemini

# Google Gemini API key from Google AI Studio.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# NVIDIA NIM API key from NVIDIA Build.
# To use it, set LLM_PROVIDER=nvidia and fill NVIDIA_API_KEY.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1

# Optional override for whichever provider is selected.
# ANSWER_MODEL=
# EVAL_MODELS=

# Ask the provider for strict JSON output via response_format. Default on;
# answer.py falls back to prompt-only JSON if a provider/model rejects it.
# LLM_JSON_MODE=true

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Retrieval settings.
TOP_K=4
RETRIEVAL_MAX_DISTANCE=1.2
