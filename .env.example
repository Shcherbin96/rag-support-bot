# Скопируй этот файл в .env и впиши свои ключи.
# .env в git НЕ попадает (он в .gitignore) — ключи остаются только у тебя.

# Бесплатный ключ Google Gemini: aistudio.google.com -> Get API key (нужен VPN для РФ)
GEMINI_API_KEY=

# Токен Telegram-бота от @BotFather (понадобится на этапе бота)
TELEGRAM_BOT_TOKEN=
